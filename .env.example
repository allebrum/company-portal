# Hoppa — environment. Copy to .env and fill in. The authoritative schema is
# apps/api/src/env.ts. For a one-command self-host, only the REQUIRED block and
# the first-run admin matter (docker-compose.yml supplies the rest).

# ── Required ────────────────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=8080
# Connection strings. With docker-compose these point at the bundled services;
# self-hosting against your own infra, set them to your Postgres / Redis.
DATABASE_URL=postgres://hoppa:hoppa@localhost:5432/hoppa
REDIS_URL=redis://localhost:6379
# Session signing key — generate with: openssl rand -hex 32
SESSION_SECRET=replace-me-with-openssl-rand-hex-32
# Public origin the browser uses. Single-container self-host = the app's URL.
WEB_ORIGIN=http://localhost:8080

# ── First-run admin (consumed once by db:init to seed the break-glass admin) ──
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-min-8-chars
# Comma-separated domains allowed to sign in via Google. Empty = any domain.
ALLOWED_EMAIL_DOMAINS=

# ── Single-container self-host (set by docker-compose; here for reference) ────
# When true, the API also serves the static web build at / (one origin).
SERVE_WEB=true
WEB_DIST_DIR=/app/apps/web/out

# ── docker-compose knobs (optional; defaults shown) ──────────────────────────
# POSTGRES_USER=hoppa
# POSTGRES_PASSWORD=hoppa
# POSTGRES_DB=hoppa
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# APP_PORT=8080

# ── Web build-time (only when building the web separately) ────────────────────
# Origin of the API. Leave EMPTY for same-origin single-container serving.
# NEXT_PUBLIC_API_URL=

# ── Google OAuth (optional; sign-in stays password-only until all three set) ──
# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
# OAUTH_REDIRECT_URL=http://localhost:8080/api/auth/google/callback

# ── Google Drive / Gmail integrations (optional; reuse the OAuth client) ──────
# Redirects default to the API origin's callback paths if unset.
# DRIVE_OAUTH_REDIRECT_URL=http://localhost:8080/api/integrations/drive/callback
# GMAIL_OAUTH_REDIRECT_URL=http://localhost:8080/api/integrations/gmail/callback

# ── WebAuthn / passkeys (optional; derived from WEB_ORIGIN if unset) ──────────
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_ORIGIN=http://localhost:8080

# ── Stripe billing / SaaS mode (OPTIONAL — leave unset for self-host) ─────────
# When STRIPE_SECRET_KEY is set, Hoppa enables billing: a self-owned 30-day
# trial, off-session recurring charges from the env price below (no Stripe
# Prices/Products/Subscriptions), and subscription gating that blocks
# past_due/canceled workspaces. The portal is the system of record (DB + Stripe
# + daily cron); signup itself runs on the separate marketing site's BFF, which
# calls the /billing endpoints below. The internal/default workspace is
# billing_exempt. Self-hosters leave these unset. See STRIPE_BILLING_REWORK.md.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...          # from the Stripe webhook endpoint
# MONTHLY_PRICE_CENTS=2999                 # smallest currency unit ($29.99)
# BILLING_CURRENCY=usd
# TRIAL_DAYS=30
# BILLING_INTERVAL_DAYS=30
# BILLING_MAX_RETRIES=4                    # past_due retries before canceled
# Shared secret with the marketing BFF: when set, /billing/signup +
# /billing/complete + /billing/status-by-ref require a matching X-Signup-Key
# header (so only the BFF can drive signup). Leave unset for self-host.
# SIGNUP_BFF_SECRET=shared-with-marketing-bff

# ── Legacy marketing-owned billing (vestigial — dormant unless set) ───────────
# The HMAC provisioning webhook + remote MARKETING_API_* subscription client
# predate this model (portal now owns billing locally + the marketing BFF drives
# signup). Kept dormant; not needed for the Stripe flow above.
# PROVISIONING_SECRET=shared-hmac-secret

# ── Web build-time (Next.js NEXT_PUBLIC_*) ───────────────────────────────────
# Signup lives on the marketing site; the portal's /signup route redirects here
# (so old links don't 404). Unset → falls back to /login.
# NEXT_PUBLIC_MARKETING_SIGNUP_URL=https://hoppa.app/signup

# ── Analytics (optional; web build-time) ─────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
