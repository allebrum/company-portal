# Hoppa — environment. Copy to .env and fill in. The authoritative schema is
# apps/api/src/env.ts. For a one-command self-host, only the REQUIRED block and
# the first-run admin matter (docker-compose.yml supplies the rest).

# ── Required ────────────────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=8080
# Connection strings. With docker-compose these point at the bundled services;
# self-hosting against your own infra, set them to your Postgres / Redis.
DATABASE_URL=postgres://hoppa:hoppa@localhost:5432/hoppa
REDIS_URL=redis://localhost:6379
# Session signing key — generate with: openssl rand -hex 32
SESSION_SECRET=replace-me-with-openssl-rand-hex-32
# Public origin the browser uses. Single-container self-host = the app's URL.
WEB_ORIGIN=http://localhost:8080

# ── Supabase (Auth / DB / Realtime / Storage) ────────────────────────────────
# `supabase start` prints these for local dev (API URL :54321 + anon/service
# keys). In the cloud, copy them from the project's API settings. The anon key
# is public (shipped to the browser); the service-role key is server-only and
# bypasses RLS — never expose it client-side.
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Web build-time (Next inlines NEXT_PUBLIC_*). Mirror the two public values:
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
#
# DATABASE_URL for a CLOUD Supabase project: the direct host
# (db.<ref>.supabase.co:5432) is IPv6-only, so on IPv4 networks use the POOLER:
#   session mode (migrations / long-running):  port 5432, user postgres.<ref>
#   transaction mode (serverless functions):   port 6543, user postgres.<ref>
# Find the exact pooler host (aws-0 / aws-1 / region) in Dashboard → Connect.
# DATABASE_URL=postgresql://postgres.<ref>:<db-password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# ── First-run admin (consumed once by db:init to seed the break-glass admin) ──
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-min-8-chars
# Comma-separated domains allowed to sign in via Google. Empty = any domain.
ALLOWED_EMAIL_DOMAINS=

# ── Single-container self-host (set by docker-compose; here for reference) ────
# When true, the API also serves the static web build at / (one origin).
SERVE_WEB=true
WEB_DIST_DIR=/app/apps/web/out

# ── docker-compose knobs (optional; defaults shown) ──────────────────────────
# POSTGRES_USER=hoppa
# POSTGRES_PASSWORD=hoppa
# POSTGRES_DB=hoppa
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# APP_PORT=8080

# ── Web build-time (only when building the web separately) ────────────────────
# Origin of the API. Leave EMPTY for same-origin single-container serving.
# NEXT_PUBLIC_API_URL=

# ── Google OAuth (optional; sign-in stays password-only until all three set) ──
# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
# OAUTH_REDIRECT_URL=http://localhost:8080/api/auth/google/callback

# ── Google Drive / Gmail integrations (optional; reuse the OAuth client) ──────
# Redirects default to the API origin's callback paths if unset.
# DRIVE_OAUTH_REDIRECT_URL=http://localhost:8080/api/integrations/drive/callback
# GMAIL_OAUTH_REDIRECT_URL=http://localhost:8080/api/integrations/gmail/callback

# ── WebAuthn / passkeys (optional; derived from WEB_ORIGIN if unset) ──────────
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_ORIGIN=http://localhost:8080

# ── SaaS billing gate (OPTIONAL — leave unset for self-host) ─────────────────
# Billing (Stripe, signup, recurring charges, webhooks) lives ENTIRELY in the
# separate marketing service (allebrum/company-portal-saas), which writes the
# `tenants` billing columns in THIS database. The portal has NO Stripe — it only
# READS those columns to gate, and exposes the HMAC identity contract the
# marketing service calls. The internal/default workspace is billing_exempt.
# Self-hosters leave all of these unset → ungated, no billing.
#
# Shared HMAC secret with the marketing service (must match its
# PROVISIONING_SECRET). When set, mounts /provisioning/account + /handoff +
# /billing-ref/validate.
# PROVISIONING_SECRET=shared-with-marketing-service
# Marketing base URL — the in-app "manage billing" button redirects here.
# MARKETING_ORIGIN=https://hoppa-marketing-s7y49.ondigitalocean.app
# Turn the subscription gate ON ("true"/"1"). Unset/false → every workspace is
# treated active (self-host / pre-billing).
# BILLING_ENFORCED=true

# ── Web build-time (Next.js NEXT_PUBLIC_*) ───────────────────────────────────
# Signup lives on the marketing site; the portal's /signup route redirects here
# (so old links don't 404). Unset → falls back to /login.
# NEXT_PUBLIC_MARKETING_SIGNUP_URL=https://hoppa.app/signup

# ── Analytics (optional; web build-time) ─────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# PostHog Support chat widget identity verification (api runtime; optional).
# The team's secret_api_token from PostHog → Support → Settings. When set,
# GET /auth/posthog-identity HMAC-signs the user's id so support tickets
# follow them across browsers/devices. Unset → widget uses browser-session
# tickets. The widget itself is enabled in PostHog Support settings, not here.
# POSTHOG_IDENTITY_SECRET=phs_...
