# --- API ---
NODE_ENV=development
API_PORT=8080
DATABASE_URL=postgres://allebrum:allebrum@localhost:5432/allebrum
REDIS_URL=redis://localhost:6379
SESSION_SECRET=replace-me-with-openssl-rand-hex-32
WEB_ORIGIN=http://localhost:3000

# --- Google OAuth (optional; sign-in stays password-only until all 3 are set) ---
# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
# OAUTH_REDIRECT_URL=http://localhost:8080/api/auth/google/callback

# --- Google Drive media manager (optional; reuses the OAuth client above) ---
# Enable the Drive API in Google Cloud and add this redirect URI to the OAuth client.
# Defaults to the API origin's /api/integrations/drive/callback if unset.
# DRIVE_OAUTH_REDIRECT_URL=http://localhost:8080/api/integrations/drive/callback

# --- Web (inlined at build time) ---
NEXT_PUBLIC_API_URL=http://localhost:8080
