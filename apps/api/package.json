{
  "name": "@allebrum/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@allebrum/shared": "workspace:*",
    "@simplewebauthn/server": "^13.3.0",
    "@socket.io/redis-adapter": "8.3.0",
    "argon2": "0.41.1",
    "compression": "1.7.5",
    "connect-redis": "7.1.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "drizzle-orm": "0.36.0",
    "express": "4.21.1",
    "express-session": "1.18.1",
    "google-auth-library": "^10.6.2",
    "helmet": "8.0.0",
    "ioredis": "5.4.1",
    "otplib": "^13.4.0",
    "pino": "9.4.0",
    "pino-http": "10.3.0",
    "postgres": "3.4.5",
    "qrcode": "^1.5.4",
    "socket.io": "4.8.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/compression": "1.7.5",
    "@types/cookie-parser": "1.4.7",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/express-session": "1.18.0",
    "@types/node": "20.16.10",
    "@types/qrcode": "^1.5.6",
    "drizzle-kit": "0.27.0",
    "pino-pretty": "11.2.2",
    "tsx": "4.19.1",
    "typescript": "5.6.3"
  }
}
