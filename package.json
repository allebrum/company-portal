{
  "name": "modernzen-company-portal",
  "version": "1.0.0",
  "private": true,
  "description": "Modern Zen company portal — Next.js static (Netlify) + Supabase (Auth/DB/Realtime/Storage)",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm --filter @modernzen/shared build && pnpm --filter @modernzen/api build && pnpm --filter @modernzen/web build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "db:generate": "pnpm --filter @modernzen/api db:generate",
    "db:migrate": "pnpm --filter @modernzen/api db:migrate",
    "db:push": "pnpm --filter @modernzen/api db:push",
    "db:seed": "pnpm --filter @modernzen/api db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "@types/node": "20.16.10",
    "supabase": "^2.107.0",
    "typescript": "5.6.3"
  },
  "dependencies": {
    "serverless-http": "^4.0.0"
  }
}
