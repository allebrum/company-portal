{
  "name": "allebrum-company-portal",
  "version": "1.0.0",
  "private": true,
  "description": "Allebrum internal portal — Next.js static + Express/Socket.IO + Postgres + Redis",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm --filter @allebrum/shared build && pnpm --filter @allebrum/api build && pnpm --filter @allebrum/web build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "db:generate": "pnpm --filter @allebrum/api db:generate",
    "db:migrate": "pnpm --filter @allebrum/api db:migrate",
    "db:push": "pnpm --filter @allebrum/api db:push",
    "db:seed": "pnpm --filter @allebrum/api db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "typescript": "5.6.3",
    "@types/node": "20.16.10"
  }
}
